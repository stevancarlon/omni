# Copy this file to .env. The backend and Docker Compose load it locally.

# PostgreSQL started by docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=omni_backend_dev

# Local contributor mode: anonymous sessions and no billing requirement.
# Never enable this on a public or production server.
COMMUNITY_MODE=true

# Pick exactly one LLM provider below. Gemini is the screenshot-capable default.
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-pro
GEMINI_API_KEY=replace-with-your-gemini-key

# Alternative LLM providers (change DEFAULT_LLM_PROVIDER and model too):
# DEFAULT_LLM_PROVIDER=groq
# DEFAULT_LLM_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=replace-with-your-groq-key
#
# DEFAULT_LLM_PROVIDER=openai
# DEFAULT_LLM_MODEL=gpt-5.5
# OPENAI_API_KEY=replace-with-your-openai-key
#
# DEFAULT_LLM_PROVIDER=claude
# DEFAULT_LLM_MODEL=claude-opus-4-6
# ANTHROPIC_API_KEY=replace-with-your-anthropic-key

# Recommended for wake-word and streaming voice recognition.
# The key needs permission to create temporary auth grants.
# DEEPGRAM_API_KEY=replace-with-your-deepgram-key

# Optional: OpenAI is also used for Whisper transcription refinement and the
# generated installed-app inventory, even when another provider drives the agent.
# OPENAI_API_KEY=replace-with-your-openai-key

# Hosted/store distributions only. Community contributors do not need these.
# GOOGLE_WEB_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
# GOOGLE_PLAY_PACKAGE_NAME=com.omni.orb
# GOOGLE_PLAY_PRO_PRODUCT_ID=omni_pro_monthly
# GOOGLE_PLAY_UNLIMITED_PRODUCT_ID=omni_unlimited_monthly
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_B64=base64-encoded-service-account-json
# APTOIDE_PACKAGE_NAME=com.omni.orb
# APTOIDE_PRO_PRODUCT_ID=omni_pro_monthly
# APTOIDE_UNLIMITED_PRODUCT_ID=omni_unlimited_monthly
# APTOIDE_API_KEY=replace-with-your-aptoide-key
# STRIPE_SECRET_KEY=sk_test_replace-me
# STRIPE_WEBHOOK_SECRET=whsec_replace-me
