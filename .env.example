# Copy to .env and fill in your keys
# The backend loads this automatically in local Mix tasks.

# Local Docker Postgres defaults.
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=postgres
export POSTGRES_HOST=localhost
export POSTGRES_PORT=55432
export POSTGRES_DB=omni_backend_dev

# Enables anonymous local community sessions and bypasses paid entitlements.
# Never enable this on the official hosted service or an untrusted public server.
export COMMUNITY_MODE=true

export DEFAULT_LLM_PROVIDER=groq
export DEFAULT_LLM_MODEL=llama-3.3-70b-versatile
export GROQ_API_KEY=gsk_...
# Alternate Groq model option:
# export DEFAULT_LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
export DEEPGRAM_API_KEY=...
export STRIPE_SECRET_KEY=sk_test_...
export STRIPE_WEBHOOK_SECRET=whsec_...

# Google sign-in / Android subscriptions
export GOOGLE_WEB_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
export GOOGLE_PLAY_PACKAGE_NAME=com.omni.orb
export GOOGLE_PLAY_PRO_PRODUCT_ID=omni_pro_monthly
export GOOGLE_PLAY_UNLIMITED_PRODUCT_ID=omni_unlimited_monthly
# Paste the full Google Play service account JSON as one shell-escaped string, or use
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_B64 with the base64-encoded JSON file contents.
export GOOGLE_PLAY_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# export GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_B64=base64-encoded-service-account-json

# Aptoide Connect in-app product access passes
export APTOIDE_PACKAGE_NAME=com.omni.orb
export APTOIDE_PRO_PRODUCT_ID=omni_pro_monthly
export APTOIDE_UNLIMITED_PRODUCT_ID=omni_unlimited_monthly
# Optional for Aptoide APIs that require authentication. Product verification does not require it.
export APTOIDE_API_KEY=your-aptoide-connect-api-key
